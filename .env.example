EXPO_PUBLIC_API_ENV=PROD
# Optional: override the API host (e.g., for tunnels or QA sandboxes)
# EXPO_PUBLIC_API_BASE_URL=https://api.dawnotemu.app

# RevenueCat SDK keys (from RevenueCat dashboard > API keys)
# iOS: appl_ prefix for App Store, test_ prefix for sandbox
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
# Android: goog_ prefix for Play Store, test_ prefix for sandbox
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=
